# ── 邮箱（IMAP 收件）──
# 本项目变量名；若服务器已用 OpenClaw 的 QQ_MAIL_* 变量，可不填这里，
# 程序会自动从 MAIL_ENV_FILE 指向的 .env 读取 QQ_MAIL_USER / QQ_MAIL_PASS 等。
QQ_EMAIL=your_qq@example.com
QQ_EMAIL_PASSWORD=your_authorization_code
QQ_IMAP_HOST=imap.qq.com
QQ_IMAP_PORT=993
QQ_MAILBOX=INBOX

# 服务器已配好的邮箱 .env 路径（OpenClaw qq-mail-mcp）。存在则自动读取其中的
# QQ_MAIL_USER / QQ_MAIL_PASS / QQ_MAIL_IMAP_HOST / QQ_MAIL_IMAP_PORT
MAIL_ENV_FILE=/root/.openclaw/tools/qq-mail-mcp/.env

# 轮询间隔（秒）
MAIL_POLL_SECONDS=300

# ── 出图 ──
# LibreOffice 可执行文件路径（留空自动探测 soffice/libreoffice）
SOFFICE_BIN=
# PIL 回退方案的中文字体路径（仅当 LibreOffice 不可用时使用）
REPORT_FONT_PATH=

# ── 发送（OpenClaw → 微信）──
# 默认绕过通用 `openclaw message send`，直接复用 openclaw-weixin 账号凭据投递，
# 避免 OpenClaw core 返回 Message ID 但微信端实际不可见。
# OPENCLAW_WEIXIN_TO 是目标微信用户 id，通常形如 xxx@im.wechat。
OPENCLAW_WEIXIN_TO=your_weixin_user_id@im.wechat
# 占位符：{to}=微信用户 id {image}=图片路径 {caption}=标题/文字。
OPENCLAW_SEND_COMMAND=node scripts/weixin_direct_send.js --json --to "{to}" --media "{image}" --message "{caption}"
OPENCLAW_SEND_TEXT_COMMAND=node scripts/weixin_direct_send.js --json --to "{to}" --message "{caption}"
